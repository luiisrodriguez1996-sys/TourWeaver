
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA GLOBALES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica si el usuario es administrador consultando la colección protegida.
    // Usamos get() directamente; si el documento no existe o isAdmin no es true, la regla falla.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true;
    }

    // Validadores de tipos de datos básicos.
    function isValidString(val) { return val is string && val.size() > 0; }

    // --- REGLAS DE COLECCIONES ---

    // Configuración del sitio: Lectura pública, escritura solo admin.
    match /siteConfigurations/{siteConfigurationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Roles de administrador: El usuario ve el suyo, admin ve todos. No se crean desde la app.
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    // Telemetría de visitas: Creación pública, gestión solo admin.
    match /tourVisits/{visitId} {
      allow create: if request.resource.data.keys().hasAll(['tourId', 'timestamp', 'userAgent'])
                    && request.resource.data.tourId is string;
      
      // Permitimos actualización limitada (para duración y clics) sin ser admin,
      // siempre que no se cambien datos base.
      allow update: if request.resource.data.tourId == resource.data.tourId
                    && (request.resource.data.duration is number || !request.resource.data.keys().contains('duration'))
                    && (request.resource.data.contacted is bool || !request.resource.data.keys().contains('contacted'));

      allow get, list, delete: if isAdmin();
    }

    // Tours y Propiedades: Núcleo de la aplicación.
    match /tours/{tourId} {
      // Lectura: Público ve lo publicado, Admin ve todo. 
      // Se añade comprobación de existencia (resource != null) para evitar errores.
      allow get, list: if (resource != null && resource.data.published == true) || isAdmin();
      
      // Escritura: Solo administradores con validación de campos mínimos.
      allow create, update: if isAdmin() && 
        isValidString(request.resource.data.name) && 
        isValidString(request.resource.data.slug);
      
      // Eliminación: Permitida para cualquier administrador.
      allow delete: if isAdmin();

      // Subcolecciones (Escenas, Hotspots, Anotaciones):
      // Usamos un comodín recursivo para asegurar que el admin tenga control total sobre los hijos del tour.
      match /{allSubcollections=**} {
        // El acceso de lectura depende de si el tour padre es público o si eres admin.
        allow read: if isAdmin() || get(/databases/$(database)/documents/tours/$(tourId)).data.published == true;
        
        // Escritura total en subcolecciones para administradores.
        allow write: if isAdmin();
      }
    }
  }
}
