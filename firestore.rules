
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE AYUDA GLOBALES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidString(val) { return val is string && val.size() > 0; }
    
    // Validadores de formato (Regex)
    function isValidEmail(val) {
      return val == null || (val is string && val.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'));
    }
    
    function isValidPhone(val) {
      return val == null || (val is string && val.matches('^\\+?[0-9\\s\\-\\(\\)]{7,20}$'));
    }
    
    function isValidWhatsApp(val) {
      return val == null || (val is string && val.matches('^[0-9]{7,15}$'));
    }

    // --- REGLAS DE COLECCIONES ---

    match /siteConfigurations/{siteConfigurationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /tourVisits/{visitId} {
      allow create: if request.resource.data.keys().hasAll(['tourId', 'timestamp', 'userAgent'])
                    && request.resource.data.tourId is string;
      
      allow update: if request.resource.data.tourId == resource.data.tourId
                    // Blindaje: La duración solo puede aumentar
                    && (!request.resource.data.keys().contains('duration') || request.resource.data.duration >= resource.data.duration)
                    // Blindaje: Si ya fue contactado, no puede volver a false
                    && (!request.resource.data.keys().contains('contacted') || (request.resource.data.contacted == true || resource.data.contacted == false))
                    // Blindaje: Los métodos de contacto no pueden ser eliminados, solo añadidos
                    && (!request.resource.data.keys().contains('contactMethods') || request.resource.data.contactMethods.hasAll(resource.data.contactMethods));

      allow get, list, delete: if isAdmin();
    }

    match /slug_registry/{slug} {
      // Unicidad de Slugs: Lectura pública, escritura solo admin
      allow get: if true;
      allow create, delete: if isAdmin();
    }

    match /tours/{tourId} {
      // Lectura pública si está publicado, o acceso total si es admin
      allow get, list: if (resource != null && resource.data.published == true) || isAdmin();
      
      allow create, update: if isAdmin() && 
        isValidString(request.resource.data.name) && 
        isValidString(request.resource.data.slug) &&
        isValidEmail(request.resource.data.contactEmail) &&
        isValidPhone(request.resource.data.contactPhone) &&
        isValidWhatsApp(request.resource.data.contactWhatsApp);
      
      allow delete: if isAdmin();

      match /{allSubcollections=**} {
        allow read: if isAdmin() || get(/databases/$(database)/documents/tours/$(tourId)).data.published == true;
        allow write: if isAdmin();
      }
    }
  }
}
