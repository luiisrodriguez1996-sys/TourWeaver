rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica que el documento exista Y que el campo isAdmin sea true (booleano)
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- COLLECTION RULES ---

    match /siteConfigurations/{siteConfigurationId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Solo se gestiona desde la consola de Firebase
    }

    match /tours/{tourId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /scenes/{sceneId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();

        match /hotspots/{hotspotId} {
          allow get, list: if true;
          allow create, update, delete: if isAdmin();
        }
      }
    }
  }
}
