
{
  "entities": {
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "description": "Represents a user with administrative privileges.",
      "properties": {
        "id": { "type": "string" },
        "isAdmin": { "type": "boolean", "description": "True if the user has administrator rights." }
      },
      "required": ["isAdmin"]
    },
    "SiteConfiguration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SiteConfiguration",
      "type": "object",
      "description": "Stores site-wide configurations.",
      "properties": {
        "id": { "type": "string" },
        "defaultLanguage": { "type": "string" },
        "contactWhatsApp": { "type": "string" },
        "contactPhone": { "type": "string" },
        "contactEmail": { "type": "string" },
        "googleAnalyticsId": { "type": "string", "description": "Google Analytics Measurement ID (G-XXXXX)" },
        "googleSearchConsoleCode": { "type": "string", "description": "Google Search Console verification code (content attribute of the meta tag)" }
      }
    },
    "Tour": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tour",
      "type": "object",
      "description": "Represents a virtual tour with multiple scenes and hotspots.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Tour entity."
        },
        "name": {
          "type": "string",
          "description": "The public name of the tour/property."
        },
        "clientName": {
          "type": "string",
          "description": "The private name of the client associated with this tour."
        },
        "slug": {
          "type": "string",
          "description": "A URL-friendly slug for the tour."
        },
        "description": {
          "type": "string",
          "description": "A description of the tour."
        },
        "published": {
          "type": "boolean",
          "description": "Indicates whether the tour is published and publicly accessible."
        },
        "showInPortfolio": {
          "type": "boolean",
          "description": "Indicates whether the tour should be shown in the home portfolio."
        },
        "floors": {
          "type": "array",
          "description": "List of floors associated with the property.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "imageUrl": { "type": "string", "format": "uri" }
            }
          }
        },
        "showFloorPlan": {
          "type": "boolean",
          "description": "Indicates whether the floor plan should be visible in the public tour."
        },
        "sceneIds": {
          "type": "array",
          "description": "References to Scenes. (Relationship: Tour 1:N Scene)",
          "items": {
            "type": "string"
          }
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "URL of the thumbnail image for the tour."
        },
        "address": {
          "type": "string",
          "description": "The physical address of the property."
        },
        "googleMapsUrl": {
          "type": "string",
          "description": "Manual link to Google Maps for the property location.",
          "format": "uri"
        },
        "contactPhone": {
          "type": "string",
          "description": "Contact phone number for the property."
        },
        "contactEmail": {
          "type": "string",
          "description": "Contact email address for the property."
        },
        "contactWhatsApp": {
          "type": "string",
          "description": "WhatsApp number (international format) for the property."
        }
      },
      "required": [
        "id",
        "name",
        "clientName",
        "slug",
        "description",
        "published"
      ]
    },
    "Scene": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Scene",
      "type": "object",
      "description": "Represents a 360° scene within a virtual tour.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Scene entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the scene."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the 360° image for the scene.",
          "format": "uri"
        },
        "tourId": {
          "type": "string",
          "description": "Reference to Tour."
        },
        "floorId": {
          "type": "string",
          "description": "Reference to a specific floor defined in the Tour."
        },
        "description": {
          "type": "string"
        },
        "floorPlanX": {
          "type": "number"
        },
        "floorPlanY": {
          "type": "number"
        },
        "hotspots": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Hotspot"
          }
        },
        "annotations": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/Annotation"
          }
        }
      },
      "required": [
        "id",
        "name",
        "imageUrl",
        "tourId"
      ]
    },
    "Hotspot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Hotspot",
      "type": "object",
      "description": "Represents a hotspot within a 360° scene.",
      "properties": {
        "id": { "type": "string" },
        "yaw": { "type": "number" },
        "pitch": { "type": "number" },
        "targetSceneId": { "type": "string" },
        "label": { "type": "string" },
        "sceneId": { "type": "string" }
      }
    },
    "Annotation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Annotation",
      "type": "object",
      "description": "Represents an information point within a 360° scene.",
      "properties": {
        "id": { "type": "string" },
        "yaw": { "type": "number" },
        "pitch": { "type": "number" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "sceneId": { "type": "string" }
      }
    },
    "TourVisit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TourVisit",
      "type": "object",
      "description": "Represents a single view of a tour.",
      "properties": {
        "id": { "type": "string" },
        "tourId": { "type": "string" },
        "timestamp": { "type": "number" },
        "userAgent": { "type": "string" },
        "duration": { "type": "number", "description": "Time spent in seconds." },
        "contacted": { "type": "boolean", "description": "Whether the user clicked a contact button." },
        "contactMethods": { "type": "array", "items": { "type": "string" }, "description": "List of contact methods clicked (whatsapp, phone, email)." }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "siteConfigurations/{siteConfigurationId}",
        "definition": {
          "entityName": "SiteConfiguration",
          "schema": { "$ref": "#/backend/entities/SiteConfiguration" },
          "description": "Stores site-wide configurations."
        }
      },
      {
        "path": "tours/{tourId}",
        "definition": {
          "entityName": "Tour",
          "schema": { "$ref": "#/backend/entities/Tour" },
          "description": "Stores tour metadata."
        }
      },
      {
        "path": "tours/{tourId}/scenes/{sceneId}",
        "definition": {
          "entityName": "Scene",
          "schema": { "$ref": "#/backend/entities/Scene" },
          "description": "Stores scene data."
        }
      },
      {
        "path": "roles_admin/{userId}",
        "definition": {
          "entityName": "AdminUser",
          "schema": { "$ref": "#/backend/entities/AdminUser" },
          "description": "Collection used to manage administrator roles."
        }
      },
      {
        "path": "tourVisits/{visitId}",
        "definition": {
          "entityName": "TourVisit",
          "schema": { "$ref": "#/backend/entities/TourVisit" },
          "description": "Logs of tour visits."
        }
      }
    ]
  }
}
